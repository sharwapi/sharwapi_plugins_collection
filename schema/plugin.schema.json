{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "SharwAPI Plugin Manifest",
    "description": "Schema for SharwAPI plugin registry files (version 1.0)",
    "type":"object",
    "required": ["id", "auth", "name", "author", "description_en", "url"],
    "properties": {
        "$schema": {
            "type": "string",
            "description": "Defines the schema location"
        },
        "id": {
            "type": "string",
            "description": "Format: author.pluginname (e.g. sharwapi.guard). Only lowercase letters, numbers and hyphens allowed.",
            "pattern": "^[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*$"
        },
        "auth": {
          "type": "object",
          "description": "Authentication keys for verifying plugin integrity",
          "properties": {
            "gpg_fingerprint": {
              "type": "string",
              "description": "The full fingerprint of the GPG key used to sign commits",
              "pattern": "^[A-F0-9]{40}$"
            },
            "ssh_pubkey": {
              "type": "string",
              "description": "Public SSH key for verification"
            }
          },
          "minProperties": 1,
          "additionalProperties": false
        },
        "name": {
            "type": "string",
            "description": "Display name of the plugin",
            "minLength": 3,
            "maxLength": 30
        },
        "author": {
            "type": "string",
            "description": "Author's name",
            "minLength": 3,
            "maxLength": 50
        },
        "description_en": {
            "type": "string",
            "description": "Description of the plugin in English",
            "minLength": 10,
            "maxLength": 200
        },
        "description_zh": {
            "type": "string",
            "description": "Description of the plugin in Chinese",
            "minLength": 10,
            "maxLength": 100
        },
        "url": {
            "type": "string",
            "description": "URL to the plugin's repository",
            "format": "uri",
            "pattern": "^https?://"
        }
    },
    "additionalProperties": false
}